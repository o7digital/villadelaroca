---
import Header from "../components/site/Header.astro";
import Footer from "../components/site/Footer.astro";

type Locale = "en" | "es";
type PageKey = "home" | "our-bb" | "room" | "rates" | "activities" | "contact";

interface Props {
  lang: string;
  headHtml: string;
  bodyClass: string;
  locale: Locale;
  currentPage: PageKey;
  currentPath: string;
  switchHref: string;
  contentHtml: string;
  tailHtml: string;
}

const {
  lang,
  headHtml,
  bodyClass,
  locale,
  currentPage,
  currentPath,
  switchHref,
  contentHtml,
  tailHtml,
} = Astro.props;

const isSpanish = locale === "es";
const englishHref = isSpanish ? switchHref : currentPath;
const spanishHref = isSpanish ? currentPath : switchHref;
---

<html lang={lang}>
  <head>
    <Fragment set:html={headHtml} />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6HKQY8FR76"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-6HKQY8FR76");
    </script>
  </head>
  <body class={bodyClass}>
    <div id="page_wrapper">
      <Header locale={locale} currentPage={currentPage} currentPath={currentPath} switchHref={switchHref} />
      <Fragment set:html={contentHtml} />
      <Footer locale={locale} />
      <div class="secondary_nav_widgetized_area">
        <div class="mobile-language-links" role="navigation" aria-label={isSpanish ? "Selector de idioma" : "Language selector"}>
          <ul class="mobile-language-flags">
            <li>
              <a
                href={englishHref}
                hreflang="en"
                title="English"
                aria-label="Switch to English"
                aria-current={!isSpanish ? "page" : undefined}
                class={`lang-flag-mobile lang-flag-en${!isSpanish ? " is-active" : ""}`}
              >
                <span class="screen-reader-text">English</span>
              </a>
            </li>
            <li>
              <a
                href={spanishHref}
                hreflang="es"
                title="Español"
                aria-label="Cambiar a español"
                aria-current={isSpanish ? "page" : undefined}
                class={`lang-flag-mobile lang-flag-es${isSpanish ? " is-active" : ""}`}
              >
                <span class="screen-reader-text">Español</span>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
    <Fragment set:html={tailHtml} />
  </body>
</html>
