---
interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const privacyLabel = lang === 'en' ? 'Privacy Policy' : 'Politica de Privacidad';
const noticeLabel = lang === 'en' ? 'Privacy Notice' : 'Aviso de Privacidad';
const keywordsLabel = lang === 'en' ? 'Keywords' : 'Palabras clave';

const keywordsByLang: Record<'en' | 'es', string[]> = {
  en: [
    'bed and breakfast Playa La Ropa Zihuatanejo',
    'boutique guesthouse Playa La Ropa',
    'B&B with pool Playa La Ropa',
    'ocean view rooms Zihuatanejo Bay',
    'guesthouse near Playa La Ropa',
    'romantic B&B Playa La Ropa',
    'book B&B Playa La Ropa Zihuatanejo',
    'Playa La Ropa accommodation',
    'private rooms Playa La Ropa',
    'Villa de la Roca Playa La Ropa'
  ],
  es: [
    'bed and breakfast en Playa La Ropa Zihuatanejo',
    'casa de huespedes en Playa La Ropa',
    'hospedaje con vista a la Bahia de Zihuatanejo',
    'alojamiento con piscina en Playa La Ropa',
    'reservar B&B en Playa La Ropa',
    'estancia romantica en Playa La Ropa',
    'habitaciones con vista a la bahia',
    'alojamiento tranquilo en Playa La Ropa',
    'renta de habitaciones en Playa La Ropa',
    'Villa de la Roca Playa La Ropa'
  ]
};

const keywords = keywordsByLang[lang];
---

<footer class="site-footer">
  <div class="container footer-grid">
    <p>Casa Villa de la Roca Copyright 2026</p>
    <p>
      <a href="/wp-content/uploads/2025/08/Privacy-Police-LCQC.pdf" target="_blank" rel="noopener noreferrer">{privacyLabel}</a>
      <span> | </span>
      <a href="/wp-content/uploads/2025/08/Aviso-de-Privacidad-LCQC.pdf" target="_blank" rel="noopener noreferrer">{noticeLabel}</a>
    </p>
  </div>
  <div class="container footer-keywords">
    <p class="keywords-title">{keywordsLabel}</p>
    <ul class="keywords-list">
      {keywords.map((keyword) => <li>{keyword}</li>)}
    </ul>
  </div>
</footer>
