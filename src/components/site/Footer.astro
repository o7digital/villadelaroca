---
type Locale = "en" | "es";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isSpanish = locale === "es";
const facebookUrl = "https://www.facebook.com/VilladelaRoca";
const instagramUrl = "https://www.instagram.com/villadelarocazihuatanejo";
const privacyHref = isSpanish
  ? "/assets/legacy/uploads/2025/08/Aviso-de-Privacidad-LCQC.pdf"
  : "/assets/legacy/uploads/2025/08/Privacy-Police-LCQC.pdf";
const privacyLabel = isSpanish ? "Aviso de Privacidad" : "Privacy Policy";
---

<div class="footer">
  <div class="footer_bar dark_section">
    <div class="container-fluid" style="padding-left:20px;padding-right:20px;">
      <div class="row">
        <div class="col-sm-10 text-left">
          {
            isSpanish ? (
              <span style="font-size:12px">
                <a href={privacyHref} style="font-size:12px">{privacyLabel}</a>
                {" | "}
                Casa Villa de la Roca Copyright © 2025 Todos los derechos reservados
              </span>
            ) : (
              <span style="font-size:12px">
                <a href={privacyHref} style="font-size:12px">{privacyLabel}</a>
                {" | "}
                Casa Villa de la Roca Copyright © 2025 All rights reserved
              </span>
            )
          }
          {
            isSpanish ? (
              <div class="seo-keywords" style="font-size:10.5px;color:#bfbfbf;margin-top:8px;line-height:1.6;word-break:break-word;overflow-wrap:break-word;">
                <div>hospedaje en Playa La Ropa Zihuatanejo | casa de huéspedes en Playa La Ropa | alojamiento cerca de Playa La Ropa | alojamiento con piscina en Playa La Ropa | reservar alojamiento en Playa La Ropa</div>
                <div>estancia romántica en Playa La Ropa | habitaciones cerca de Playa La Ropa | alojamiento tranquilo en Playa La Ropa | renta de habitaciones en Playa La Ropa | Villa de la Roca Playa La Ropa</div>
              </div>
            ) : (
              <div class="seo-keywords" style="font-size:10.5px;color:#bfbfbf;margin-top:8px;line-height:1.6;word-break:break-word;overflow-wrap:break-word;">
                <div>bed and breakfast Playa La Ropa Zihuatanejo | guesthouse Playa La Ropa | B&amp;B with pool Playa La Ropa | rooms near Playa La Ropa | guesthouse near Playa La Ropa</div>
                <div>romantic B&amp;B Playa La Ropa | book B&amp;B Playa La Ropa Zihuatanejo | Playa La Ropa accommodation | private rooms Playa La Ropa | Villa de la Roca Playa La Ropa</div>
              </div>
            )
          }
        </div>
        <div class="col-sm-2 text-right footer-social-col">
          <div class="social-floating" aria-label={isSpanish ? "Redes sociales" : "Social links"}>
            <a href={facebookUrl} target="_blank" rel="noopener noreferrer" aria-label="Facebook" title="Facebook">
              <i class="fa fa-facebook" aria-hidden="true"></i>
            </a>
            <a href={instagramUrl} target="_blank" rel="noopener noreferrer" aria-label="Instagram" title="Instagram">
              <i class="fa fa-instagram" aria-hidden="true"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

  <style>
  .social-floating {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 10px;
    position: fixed;
    right: calc(env(safe-area-inset-right, 0px) + clamp(10.5rem, 14vw, 13rem));
    bottom: 1.1rem;
    z-index: 9999;
  }

  .footer-social-col {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
  }

  .social-floating a {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #ffffff;
    color: #10131c !important;
    border: 1px solid rgba(0, 0, 0, 0.16);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.25);
    text-decoration: none !important;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease, color 0.2s ease;
  }

  .social-floating a i {
    font-size: 20px;
    line-height: 1;
  }

  .social-floating a:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.32);
  }

  .social-floating a[aria-label="Facebook"]:hover {
    background-color: #1877f2;
    color: #ffffff !important;
  }

  .social-floating a[aria-label="Instagram"]:hover {
    background-color: #e1306c;
    color: #ffffff !important;
  }

  @media (max-width: 767px) {
    .footer-social-col {
      margin-top: 10px;
      justify-content: flex-end;
    }

    .social-floating {
      gap: 8px;
      right: calc(env(safe-area-inset-right, 0px) + 8.25rem);
      bottom: 0.9rem;
    }

    .social-floating a {
      width: 40px;
      height: 40px;
    }
  }
</style>
