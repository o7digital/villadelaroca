---
type Locale = "en" | "es";
type PageKey = "home" | "our-bb" | "room" | "rates" | "activities" | "contact";

interface Props {
  locale: Locale;
  currentPage: PageKey;
  currentPath: string;
  switchHref: string;
}

const { locale, currentPage, currentPath, switchHref } = Astro.props;
const isSpanish = locale === "es";
const homePath = isSpanish ? "/es/" : "/";
const ourBbPath = isSpanish ? "/es/our-bb/" : "/our-bb/";
const roomPath = isSpanish ? "/es/room/room/" : "/room/room/";
const activitiesPath = isSpanish ? "/es/activities/" : "/activities/";
const contactPath = isSpanish ? "/es/contact/" : "/contact/";
const bookLabel = isSpanish ? "Reserve ahora" : "Book Now!";
const bookingLocale = isSpanish ? "es" : "en";
const englishHref = isSpanish ? switchHref : currentPath;
const spanishHref = isSpanish ? currentPath : switchHref;
const activeLanguageCode = isSpanish ? "ES" : "EN";
const alternateLanguageCode = isSpanish ? "EN" : "ES";
const alternateLanguageHref = isSpanish ? englishHref : spanishHref;
const alternateLanguageHreflang = isSpanish ? "en" : "es";

function pageClass(base: string, active: boolean) {
  return active ? `${base} current-menu-item current_page_item active` : base;
}

---

<div class="header transparent">
  <div class="mainbar">
    <div class="container">
      <div class="logo">
        <a href={homePath} class="brand">
          <img src="/assets/legacy/uploads/2022/11/logo_vdr_blanco_ok.png" alt="hotel-xenia" />
        </a>
      </div>
      <div class="main_nav_wrapper">
        <nav class="primary_nav hidden_on_header_stuck">
          <ul id="menu-villa-de-la-roca" class="top_level_ul nav hover_menu">
            <li id="menu-item-31" class={pageClass("menu-item menu-item-type-post_type menu-item-object-page menu-item-31", currentPage === "our-bb")}>
              <a title={isSpanish ? "Nosotros" : "About Us"} href={ourBbPath}>{isSpanish ? "Nosotros" : "About Us"}</a>
            </li>
            <li id="menu-item-1609" class={pageClass("menu-item menu-item-type-post_type menu-item-object-room menu-item-1609", currentPage === "room" || currentPage === "rates")}>
              <a title={isSpanish ? "Habitaciones y tarifas" : "Rooms & Rates"} href={roomPath}>
                {isSpanish ? "Habitaciones y tarifas" : "Rooms & Rates"}
              </a>
            </li>
            <li id="menu-item-1463" class={pageClass("menu-item menu-item-type-post_type menu-item-object-page menu-item-1463", currentPage === "activities")}>
              <a title={isSpanish ? "Actividades" : "Activities"} href={activitiesPath}>{isSpanish ? "Actividades" : "Activities"}</a>
            </li>
            <li id="menu-item-25" class={pageClass("menu-item menu-item-type-post_type menu-item-object-page menu-item-25", currentPage === "contact")}>
              <a title={isSpanish ? "Contactanos" : "Contact Us"} href={contactPath}>{isSpanish ? "Contactanos" : "Contact Us"}</a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
    <div class="toggler_and_tools">
      <div class="mobile-lang-switcher" role="navigation" aria-label={isSpanish ? "Selector de idioma" : "Language selector"}>
        <a class="mobile-lang-current" href={currentPath} hreflang={isSpanish ? "es" : "en"} aria-current="page">
          {activeLanguageCode}
          <svg class="lang-chevron" viewBox="0 0 10 6" width="10" height="6" aria-hidden="true">
            <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
          </svg>
        </a>
        <a class="mobile-lang-alt" href={alternateLanguageHref} hreflang={alternateLanguageHreflang}>
          {alternateLanguageCode}
        </a>
      </div>
      <div class="header_tools">
        <div class="nav_mini_tool_container">
          <a
            href={`https://direct-book.com/properties/gub5966?locale=${bookingLocale}&items[0][adults]=2&items[0][children]=0&items[0][infants]=0&currency=MXN&checkInDate=2022-11-25&checkOutDate=2022-11-26&trackPage=yes`}
            class="btn btn-inv btn-secondary"
            style="margin-top:-20px"
          >
            {bookLabel}
          </a>
        </div>
      </div>
      <a class="menu-toggler  hidden_above_threshold">
        <span class="lines  hidden_above_threshold"></span>
      </a>
    </div>
  </div>
</div>
<style is:global>
  .toggler_and_tools .mobile-lang-switcher {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    margin: 0 6px 0 8px;
    flex-shrink: 0;
    line-height: 1;
  }

  .toggler_and_tools .mobile-lang-switcher a {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: "Montserrat", sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #ffffff !important;
    text-decoration: none !important;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .toggler_and_tools .mobile-lang-switcher .mobile-lang-current {
    color: #ffffff !important;
  }

  .toggler_and_tools .mobile-lang-switcher .mobile-lang-alt {
    color: rgba(255, 255, 255, 0.95) !important;
  }

  .toggler_and_tools .mobile-lang-switcher .mobile-lang-alt:hover {
    color: rgba(209, 200, 95, 1) !important;
  }

  .toggler_and_tools .mobile-lang-switcher .lang-chevron {
    color: rgba(255, 255, 255, 0.85);
    transform: translateY(1px);
  }

  @media only screen and (min-width: 992px) {
    .toggler_and_tools .mobile-lang-switcher {
      display: inline-flex !important;
    }
  }

  @media only screen and (max-width: 991px) {
    .toggler_and_tools .mobile-lang-switcher {
      display: none !important;
    }
  }
</style>
