---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="es"
  path="/es/contact/"
  title="Contacto | Villa de la Roca"
  description="Contacta a Villa de la Roca para reservas, dudas de estancia y recomendaciones personalizadas."
  ogImage="/wp-content/uploads/2022/11/ixtapa-zihuatanejo-sea-front-bb-villa-la-roca-7.jpeg"
>
  <section
    class="hero"
    style="background-image: image-set(url('/wp-content/uploads/2022/11/ixtapa-zihuatanejo-sea-front-bb-villa-la-roca-7.webp') type('image/webp'), url('/wp-content/uploads/2022/11/ixtapa-zihuatanejo-sea-front-bb-villa-la-roca-7.jpeg') type('image/jpeg'));"
  >
    <div class="container">
      <h1>Contacto</h1>
      <p>Estamos listos para ayudarte a planear tu estancia en Zihuatanejo.</p>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2">
      <article class="card">
        <h2>Villa de la Roca</h2>
        <p>Playa La Ropa, Zihuatanejo, Guerrero, Mexico</p>
        <p>Email: <a href="mailto:info@villadelaroca.com">info@villadelaroca.com</a></p>
        <p>Telefono: <a href="tel:+527555560000">+52 755 556 0000</a></p>
      </article>
      <article class="card">
        <h2>Solicitud rapida</h2>
        <form class="grid" action="mailto:info@villadelaroca.com" method="post" enctype="text/plain">
          <input type="text" name="name" placeholder="Nombre" required />
          <input type="email" name="email" placeholder="Correo" required />
          <textarea name="message" placeholder="Mensaje" rows="5" required></textarea>
          <button class="cta" type="submit">Enviar</button>
        </form>
      </article>
    </div>
  </section>
</BaseLayout>
