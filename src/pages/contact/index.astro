---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="en"
  path="/contact/"
  title="Contact | Villa de la Roca"
  description="Contact Villa de la Roca for reservations, stay questions, and personalized recommendations."
  ogImage="/wp-content/uploads/2022/11/ixtapa-zihuatanejo-sea-front-bb-villa-la-roca-7.jpeg"
>
  <section
    class="hero"
    style="background-image: image-set(url('/wp-content/uploads/2022/11/ixtapa-zihuatanejo-sea-front-bb-villa-la-roca-7.webp') type('image/webp'), url('/wp-content/uploads/2022/11/ixtapa-zihuatanejo-sea-front-bb-villa-la-roca-7.jpeg') type('image/jpeg'));"
  >
    <div class="container">
      <h1>Contact</h1>
      <p>We are happy to help you plan your stay in Zihuatanejo.</p>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2">
      <article class="card">
        <h2>Villa de la Roca</h2>
        <p>Playa La Ropa, Zihuatanejo, Guerrero, Mexico</p>
        <p>Email: <a href="mailto:info@villadelaroca.com">info@villadelaroca.com</a></p>
        <p>Phone: <a href="tel:+527555560000">+52 755 556 0000</a></p>
      </article>
      <article class="card">
        <h2>Quick Request</h2>
        <form class="grid" action="mailto:info@villadelaroca.com" method="post" enctype="text/plain">
          <input type="text" name="name" placeholder="Name" required />
          <input type="email" name="email" placeholder="Email" required />
          <textarea name="message" placeholder="Message" rows="5" required></textarea>
          <button class="cta" type="submit">Send</button>
        </form>
      </article>
    </div>
  </section>
</BaseLayout>
