{
  "framework": "astro",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "query", "key": "p", "value": "11" }],
      "destination": "/our-bb/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "query", "key": "p", "value": "17" }],
      "destination": "/rooms-rates/rates/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "query", "key": "p", "value": "23" }],
      "destination": "/contact/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "query", "key": "p", "value": "1443" }],
      "destination": "/activities/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "query", "key": "p", "value": "1005" }],
      "destination": "/room/room/",
      "permanent": true
    }
  ]
}
